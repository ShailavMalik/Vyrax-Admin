{
  "name": "vryrax-admin",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n frontend,backend -c blue,green \"vite\" \"npm run dev:backend\"",
    "dev:backend": "npm --prefix backend run dev",
    "dev:all": "npm run dev",
    "start:backend": "npm --prefix backend run start",
