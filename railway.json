{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm --prefix backend install"
  },
  "deploy": {
    "startCommand": "npm run start:backend",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
